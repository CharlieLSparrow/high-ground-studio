# Database
# Keep this local for Studio persistence smoke tests. The smoke script refuses
# non-local database hosts so it cannot accidentally write to remote Neon.
# Matches the local Postgres service in compose.studio.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/high_ground_studio"

# Google OAuth / NextAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
AUTH_SECRET="replace-with-a-long-random-secret"
# Legacy fallback only. Current code prefers AUTH_SECRET and only checks this if AUTH_SECRET is unset.
# NEXTAUTH_SECRET="replace-with-the-same-long-random-secret"

# Role bootstrap email lists
# Comma-separated email lists. Leave blank if you do not want bootstrap role assignment.
HGO_OWNER_EMAILS="owner@example.com"
HGO_TEAM_SCHEDULER_EMAILS="scheduler@example.com"
HGO_COACH_EMAILS="coach@example.com"

# Studio live MVP auth
# Use "database" locally when exercising Prisma-backed identity. Use
# "allowlist" for the first private Cloud Run MVP before Studio has a live
# database dependency.
STUDIO_AUTH_MODE="database"
STUDIO_ALLOWED_EMAILS="owner@example.com"

HGO_COACHING_DONATION_URL="https://buy.stripe.com/your-payment-link"
HGO_COMPANY_FAMILY_SUPPORT_URL="https://example.com/family-support"

# WorldHub provider readiness
# These are optional until you intentionally enable the corresponding adapter.
# The team WorldHub page stores only env-name readiness, never secret values.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_COACHING_PRICE_ID=""
STRIPE_SUPPORTER_PRICE_ID=""
STRIPE_SUCCESS_URL="http://localhost:3000/coaching/success"
STRIPE_CANCEL_URL="http://localhost:3000/coaching/cancel"

PATREON_CLIENT_ID=""
PATREON_CLIENT_SECRET=""
PATREON_WEBHOOK_SECRET=""
PATREON_CAMPAIGN_ID=""
PATREON_CREATOR_ACCESS_TOKEN=""

GOOGLE_CALENDAR_ID="primary"
# Use either server-side service-account auth or an explicit calendar refresh token.
# Do not reuse sign-in OAuth secrets as calendar sync credentials.
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_IMPERSONATION_EMAIL=""
GOOGLE_CALENDAR_SYNC_CLIENT_ID=""
GOOGLE_CALENDAR_SYNC_CLIENT_SECRET=""
# Optional: none, externalOnly, or all. Defaults to none.
GOOGLE_CALENDAR_SEND_UPDATES="none"

HGO_MERCH_PROVIDER=""
SHOPIFY_ADMIN_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN=""
FOURTHWALL_API_KEY=""
FOURTHWALL_SHOP_URL=""
PRINTFUL_API_KEY=""
PRINTFUL_STORE_ID=""
PRINTIFY_API_KEY=""
PRINTIFY_SHOP_ID=""
GELATO_API_KEY=""
GELATO_STORE_ID=""

# Email notifications
RESEND_API_KEY="re_placeholder"
HGO_EMAIL_FROM="High Ground Odyssey <support@example.com>"
RESEND_WEBHOOK_SECRET=""
HGO_SITE_URL="http://localhost:3000"

# Content pipeline
# Optional transitional flag. Leave unset for the current guarded episodes-loader default.
# Set to 1 only when explicitly testing the Fumadocs-backed episodes source.
# ENABLE_EPISODES_FUMADOCS="1"
