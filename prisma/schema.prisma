// What this file does:
// This schema is the formal ledger of the app's durable state: who exists,
// which roles they carry, how memberships are granted, and how appointments
// are tracked.
//
// Why this matters:
// Application code is the bustling city above ground. The Prisma schema is the
// municipal registry underneath it all, where the laws of identity and
// relationship are written down so the rest of the town cannot "just wing it."
//
// Best practice (the "textbook" version):
// Model distinct concepts as distinct tables as soon as their lifecycle,
// constraints, or audit needs diverge.
//
// What we are doing instead (and why):
// A compact schema with a few well-chosen separations. The app is mature enough
// to deserve real relational structure, but not so mature that every possible
// future noun needs its own chapel and pension plan today.
//
// Tradeoff:
// We gain clarity and room to grow.
// We sacrifice some future specialization until pressure justifies it.
//
// Question for Future Charlie:
// When is a nullable column a gift, and when is it a warning?
//
// Answer:
// It is a gift when it represents optional data for the same species of thing.
// It is a warning when it tries to hide that two different species are living
// in the same table wearing one coat.
//
// First assumption that breaks:
// "One user table can gracefully stand in for every identity-adjacent concept."
//
// Future Chuck note:
// Read this file as a map of nouns and relationships, not as an arcane spell.
// Models are entities. Fields are facts about them. Relations are the bridges.
// Indexes and uniqueness rules are the town guards preventing certain classes
// of nonsense from entering the square.
//
// What it looks like now:
// A compact product schema centered on users, roles, memberships, appointments,
// and a few internal workflow helpers in application code.
//
// What it turns into later:
// More explicit identity siblings (human auth methods, email-only contacts,
// service accounts, consent ledgers) once the app needs to separate "person,"
// "login method," "marketing contact," and "machine actor."
//
// Signal to evolve it:
// The second you catch yourself trying to make one table pretend to be two
// species by adding "just one more nullable column," the fake mustache is on
// and the schema is asking for a new model instead.
//
// Footnote:
// If TypeScript files are wandering adventurers, this schema is the census
// office that eventually learns all their names, bloodlines, entitlements, and
// regrettable scheduling decisions.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Roles are stored separately from auth provider details. That is deliberate.
// A person may prove identity one way (today, Google), while the app still
// needs its own notion of what official badges that person carries.
//
// Best practice (the "textbook" version):
// Keep authentication method and authorization grant separate.
enum AppRole {
  OWNER
  TEAM_SCHEDULER
  COACH
  CLIENT
}

// Membership lifecycle inside the app. This is product state, not billing
// plumbing, which is why it can exist cleanly even while Stripe is quarantined.
enum MembershipStatus {
  ACTIVE
  PAUSED
  CANCELED
  EXPIRED
}

// Appointment state tracks the life of the scheduled event itself.
enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

// Location type tells us how the appointment happens; details live separately
// because "video" and "123 Main St." are not the same kind of fact.
enum AppointmentLocationType {
  VIDEO
  PHONE
  IN_PERSON
  OTHER
}

enum ContactPreference {
  EMAIL
  PHONE_CALL
  TEXT
}

enum CoachingRequestStatus {
  NEW
  CONTACTED
  SCHEDULED
  CLOSED
  DECLINED
}

enum WeeklyCommitmentStatus {
  ACTIVE
  REVIEWED
  ARCHIVED
}

enum StoryDraftStatus {
  ROUGH
  NEEDS_HOMER_REVIEW
  NEEDS_CHUCK_REVIEW
  APPROVED_FOR_PROMOTION
  PROMOTED
  PARKED
}

enum StudioProjectionStatus {
  private
  draft
  review
  approved
  published
  not_public
  projection_not_approved
}

enum StudioTagCategory {
  meaning
  structure
  source
  projection
  review
}

enum StudioKnowledgeNodeType {
  principle
  story
  quote
  question
  projection_candidate
  source_note
}

enum StudioManuscriptKind {
  WORKING
  SYNTHETIC
}

// The canonical human/app identity record.
//
// Source of truth:
// This is the main "person in our system" row. It is not a provider-specific
// account table, and it is not a newsletter-only contact ledger. It is the
// app's primary human record.
//
// Best practice (the "textbook" version):
// One canonical person record, with adjacent tables for concerns that have
// different lifecycles.
//
// What we are doing instead (and why):
// Precisely that, but in a still-compact way. User is the human. UserEmail and
// UserRole absorb the first obvious splits. More identity siblings can arrive
// later when they earn their keep.
//
// Why the related tables exist:
// - aliases let one human have multiple emails without duplicate users
// - roles let one human carry multiple badges
// - clientProfile separates coaching/client metadata from core identity
//
// Future complexity wearing a fake mustache:
// "I am sure User can also directly be newsletter contact, auth method store,
// and machine principal if we just add enough columns." That way lies a very
// tired table and many haunted nulls.
//
// Signal to evolve it:
// When the same email address must exist as a human account, newsletter-only
// contact, or service-account owner with different lifecycle rules, the schema
// wants adjacent models, not a larger bucket.
//
// If ignored:
// The User table turns into a wagon piled with nullable flags, and one morning
// everyone discovers they have built a very advanced machine for being vaguely
// wrong.
//
// If you poke this with a stick:
// Changing primary email rules or collapsing aliases/roles into columns looks
// simple for about six minutes, after which the family tree catches fire.
model User {
  id                  String        @id @default(cuid())
  primaryEmail        String        @unique
  name                String?
  image               String?
  newsletterOptIn     Boolean       @default(false)
  announcementsOptIn  Boolean       @default(false)
  welcomeCompletedAt  DateTime?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  aliases             UserEmail[]
  roles               UserRole[]
  clientProfile       ClientProfile?
  memberships         Membership[]  @relation("MembershipUser")
  coachingFeatureGrants CoachingFeatureGrant[] @relation("CoachingFeatureGrantUser")
  weeklyCommitments   WeeklyCommitment[] @relation("WeeklyCommitmentClient")

  clientAppointments  Appointment[] @relation("AppointmentClient")
  coachAppointments   Appointment[] @relation("AppointmentCoach")
  appointmentsCreated Appointment[] @relation("AppointmentCreatedBy")
  appointmentsUpdated Appointment[] @relation("AppointmentUpdatedBy")
  coachingRequests    CoachingRequest[] @relation("CoachingRequestClient")
  assignedCoachingRequests CoachingRequest[] @relation("CoachingRequestCoach")
  companySupportRequests CompanySupportRequest[]
  storyDraftsCreated  StoryDraft[] @relation("StoryDraftCreatedBy")
  storyDraftsUpdated  StoryDraft[] @relation("StoryDraftUpdatedBy")
  storyDraftsReviewed StoryDraft[] @relation("StoryDraftReviewedBy")

  membershipsGranted  Membership[]  @relation("MembershipGrantedBy")
  coachingFeatureGrantsGranted CoachingFeatureGrant[] @relation("CoachingFeatureGrantGrantedBy")
  weeklyCommitmentsReviewed WeeklyCommitment[] @relation("WeeklyCommitmentReviewedBy")

  collections         Collection[]
  snippets            Snippet[]
  bookmarks           Bookmark[]
}

// Alternate or secondary email addresses linked to the same human.
// This keeps "same person, different address" from turning into "two users who
// now require a summit meeting."
model UserEmail {
  id        String   @id @default(cuid())
  userId    String
  email     String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Separate role rows mean a user can hold several badges at once without
// encoding that fact into brittle booleans like `isCoachAndMaybeScheduler`.
//
// Best practice (the "textbook" version):
// Model many-to-many-ish grants as rows, not boolean confetti.
// Signal to evolve it:
// If roles start needing scopes, grant reasons, expirations, or audit history,
// the disguise comes off and this simple join table grows into a richer grant
// model.
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      AppRole
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

// Client-specific domain data hangs off User rather than bloating the base
// identity record. Not every human in the system is necessarily a client.
model ClientProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// MembershipPlan is the product catalog layer: what kinds of memberships exist
// in principle, independent of which user currently has one.
//
// Right now, this is a small internal product catalog.
// In a more mature system, plans might gain external billing identifiers,
// archival states, or country/currency rules.
// We are NOT doing that yet because memberships are still manual/internal and
// Stripe is intentionally quarantined.
model MembershipPlan {
  id                    String       @id @default(cuid())
  name                  String
  slug                  String       @unique
  description           String?
  priceCents            Int?
  billingIntervalMonths Int?
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  memberships           Membership[]
}

// Membership is the actual grant of a plan to a user.
//
// Why separate plan vs membership:
// One table describes the offer. The other records who has it, when it starts,
// when it ends, and who granted it. Catalog vs instance. Menu vs meal.
//
// Best practice (the "textbook" version):
// Separate product definition from user entitlement. Always.
//
// Future complexity wearing a fake mustache:
// "I am just a status field." Later someone wants pause reasons, billing
// handoff state, change history, and entitlement windows. That is where you
// decide whether membership state deserves a richer event trail.
model Membership {
  id              String           @id @default(cuid())
  userId          String
  planId          String
  status          MembershipStatus @default(ACTIVE)
  startsAt        DateTime         @default(now())
  endsAt          DateTime?
  grantedByUserId String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  plan            MembershipPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  grantedBy       User?            @relation("MembershipGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([planId])
}

model CoachingFeature {
  id              String   @id @default(cuid())
  featureKey      String   @unique
  title           String
  category        String   @default("tool")
  clientSummary   String
  coachSummary    String?
  status          String   @default("active")
  sortOrder       Int      @default(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  grants          CoachingFeatureGrant[]

  @@index([category, status])
  @@index([status, sortOrder])
}

model CoachingFeatureGrant {
  id              String   @id @default(cuid())
  userId          String
  featureId       String
  status          String   @default("enabled")
  source          String   @default("manual")
  visibility      String   @default("client_and_coach")
  startsAt        DateTime @default(now())
  endsAt          DateTime?
  notes           String?
  grantedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("CoachingFeatureGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  feature         CoachingFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  grantedBy       User?    @relation("CoachingFeatureGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, featureId])
  @@index([featureId, status])
  @@index([userId, status])
  @@index([source, status])
}

model WeeklyCommitment {
  id               String                 @id @default(cuid())
  clientUserId     String
  weekStartsAt     DateTime
  commitmentOne    String
  commitmentTwo    String?
  commitmentThree  String?
  supportNeeded    String?
  progressNotes    String?
  status           WeeklyCommitmentStatus @default(ACTIVE)
  coachNotes       String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  clientUser       User                   @relation("WeeklyCommitmentClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  reviewedByUser   User?                  @relation("WeeklyCommitmentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([clientUserId, weekStartsAt])
  @@index([clientUserId, status, weekStartsAt])
  @@index([status, updatedAt])
  @@index([reviewedByUserId])
}

// Appointment is the scheduling ledger tying client, coach, and creator roles
// together around one time-bounded event.
//
// Interview lens:
// Notice how this model encodes distinct relationships to User with named
// relations. One human table, many contextual roles in the same record. That is
// very common in real systems and much less scary once you see it written down.
//
// Best practice (the "textbook" version):
// Name relations explicitly whenever one table points to the same target table
// in more than one role. Otherwise future you will meet the Minotaur.
//
// Signal to evolve it:
// If appointments accumulate reminders, attendance artifacts, external sync
// metadata, or multi-party participants beyond client/coach/creator/updater,
// a separate companion model set may be cleaner than endlessly inflating this
// one municipal form.
model Appointment {
  id              String                  @id @default(cuid())
  clientUserId    String
  coachUserId     String?
  createdByUserId String
  updatedByUserId String?
  scheduledStart  DateTime
  scheduledEnd    DateTime
  timezone        String                  @default("America/Denver")
  status          AppointmentStatus       @default(SCHEDULED)
  locationType    AppointmentLocationType @default(VIDEO)
  locationDetails String?
  notes           String?
  clientNotes     String?
  googleEventId   String?                 @unique
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  clientUser      User                    @relation("AppointmentClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  coachUser       User?                   @relation("AppointmentCoach", fields: [coachUserId], references: [id], onDelete: SetNull)
  createdByUser   User                    @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser   User?                   @relation("AppointmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  coachingRequestConversion CoachingRequest?

  @@index([clientUserId, scheduledStart])
  @@index([coachUserId, scheduledStart])
  @@index([status, scheduledStart])
}

model CoachingRequest {
  id                    String                @id @default(cuid())
  clientUserId          String
  preferredContactMethod ContactPreference
  email                 String
  phone                 String?
  availabilityNotes     String?
  coachingGoals         String
  contactConsent        Boolean
  status                CoachingRequestStatus @default(NEW)
  assignedCoachUserId   String?
  convertedAppointmentId String?             @unique
  internalNotes         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  clientUser            User                  @relation("CoachingRequestClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  assignedCoachUser     User?                 @relation("CoachingRequestCoach", fields: [assignedCoachUserId], references: [id], onDelete: SetNull)
  convertedAppointment  Appointment?          @relation(fields: [convertedAppointmentId], references: [id], onDelete: SetNull)

  @@index([clientUserId, createdAt])
  @@index([status, createdAt])
  @@index([assignedCoachUserId, status])
}

model CompanySupportRequest {
  id                     String   @id @default(cuid())
  name                   String
  email                  String
  phone                  String?
  preferredContactMethod ContactPreference
  supportType            String
  note                   String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  userId                 String?

  user                   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([supportType, createdAt])
  @@index([userId, createdAt])
}

model WorldHubProviderConnection {
  id                 String   @id @default(cuid())
  providerKey        String   @unique
  providerKind       String
  displayName        String
  status             String   @default("planned")
  accountLabel       String?
  capabilitiesJson   Json
  requiredEnvJson    Json
  configuredEnvJson  Json
  missingEnvJson     Json
  setupUrl           String?
  setupNotes         String?
  healthStatus       String   @default("not_checked")
  lastCheckedAt      DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  events             WorldHubProviderEvent[]
  syncJobs           WorldHubProviderSyncJob[]
  offers             WorldHubOffer[]
  orders             WorldHubOrder[]
  fulfillmentJobs    WorldHubFulfillmentJob[]

  @@index([providerKind, status])
  @@index([status, updatedAt])
}

model WorldHubProviderEvent {
  id                 String   @id @default(cuid())
  connectionId       String
  eventType          String
  externalEventId    String?
  idempotencyKey     String?
  verificationStatus String   @default("unchecked")
  processingStatus   String   @default("received")
  payloadHash        String?
  payloadSummaryJson Json
  errorMessage       String?
  occurredAt         DateTime?
  receivedAt         DateTime @default(now())
  processedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connection         WorldHubProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, idempotencyKey])
  @@index([connectionId, receivedAt])
  @@index([processingStatus, receivedAt])
}

model WorldHubProviderSyncJob {
  id                 String   @id @default(cuid())
  connectionId       String?
  providerKey        String
  jobType            String
  subjectType        String
  subjectId          String?
  status             String   @default("queued")
  payloadJson        Json
  resultJson         Json?
  errorMessage       String?
  requestedByEmail   String?
  requestedAt        DateTime @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connection         WorldHubProviderConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([providerKey, status, requestedAt])
  @@index([subjectType, subjectId])
}

model WorldHubCatalogItem {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  kind               String
  status             String   @default("draft")
  description        String?
  fulfillmentRequired Boolean @default(false)
  metadataJson       Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([kind, status])
}

model WorldHubOffer {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  kind                 String
  status               String   @default("draft")
  checkoutMode         String   @default("external_link")
  summary              String?
  externalUrl          String?
  providerConnectionId String?
  catalogItemRefsJson  Json
  priceRefsJson        Json
  entitlementRefsJson  Json
  metadataJson         Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  providerConnection   WorldHubProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  @@index([kind, status])
  @@index([providerConnectionId, status])
}

model WorldHubCart {
  id             String   @id @default(cuid())
  cartKey        String   @unique
  ownerUserId    String?
  email          String?
  status         String   @default("draft")
  currency       String   @default("USD")
  lineItemsJson  Json
  subtotalCents  Int      @default(0)
  discountCents  Int      @default(0)
  totalCents     Int      @default(0)
  expiresAt      DateTime?
  checkedOutAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerUserId, updatedAt])
  @@index([email, updatedAt])
  @@index([status, updatedAt])
}

model WorldHubOrder {
  id                   String   @id @default(cuid())
  orderNumber          String   @unique
  sourceCartId         String?
  ownerUserId          String?
  email                String?
  status               String   @default("pending")
  currency             String   @default("USD")
  lineItemsJson        Json
  subtotalCents        Int      @default(0)
  discountCents        Int      @default(0)
  totalCents           Int      @default(0)
  checkoutMode         String   @default("provider_checkout")
  providerConnectionId String?
  externalCheckoutUrl  String?
  providerRefsJson     Json
  placedAt             DateTime?
  paidAt               DateTime?
  canceledAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  providerConnection   WorldHubProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)
  fulfillmentJobs      WorldHubFulfillmentJob[]

  @@index([ownerUserId, updatedAt])
  @@index([email, updatedAt])
  @@index([status, updatedAt])
  @@index([providerConnectionId, updatedAt])
}

model WorldHubFulfillmentJob {
  id                   String   @id @default(cuid())
  orderId              String?
  providerConnectionId String?
  status               String   @default("queued")
  lineItemsJson        Json
  providerRefsJson     Json
  queuedAt             DateTime @default(now())
  sentAt               DateTime?
  completedAt          DateTime?
  failureReason        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  order                WorldHubOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  providerConnection   WorldHubProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  @@index([orderId, status])
  @@index([providerConnectionId, status])
  @@index([status, queuedAt])
}

model WorldHubSeoBrief {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  title                 String
  contentKind           String   @default("episode_page")
  status                String   @default("draft")
  targetPath            String?
  targetUrl             String?
  primaryKeyword        String?
  secondaryKeywordsJson Json
  searchIntent          String?
  audience              String?
  metaTitle             String?
  metaDescription       String?
  canonicalUrl          String?
  ogTitle               String?
  ogDescription         String?
  structuredDataType    String?
  checklistJson         Json
  notes                 String?
  createdByEmail        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([contentKind, status])
  @@index([status, updatedAt])
  @@index([targetPath])
}

model WorldHubAnalyticsSnapshot {
  id              String   @id @default(cuid())
  source          String
  channel         String   @default("site")
  contentPath     String?
  periodStart     DateTime
  periodEnd       DateTime
  metricsJson     Json
  notes           String?
  capturedByEmail String?
  capturedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([source, capturedAt])
  @@index([channel, capturedAt])
  @@index([contentPath, capturedAt])
}

model WorldHubMonetizationPlacement {
  id             String   @id @default(cuid())
  slug           String   @unique
  placementType  String
  status         String   @default("draft")
  targetPath     String?
  providerKey    String?
  displayName    String
  destinationUrl String?
  disclosureText String?
  callToAction   String?
  metadataJson   Json
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([placementType, status])
  @@index([targetPath, status])
  @@index([providerKey, status])
}

model WorldHubMonetizationResearchNote {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  projectProfile   String
  monetizationType String
  status           String   @default("research")
  confidence       String   @default("medium")
  sourceTitle      String
  sourceUrl        String
  sourcePublisher  String?
  sourceDate       String?
  sourceAccessedAt DateTime @default(now())
  summary          String
  takeawaysJson    Json
  recommendedUse   String?
  risksJson        Json
  nextActionsJson  Json
  tagsJson         Json
  createdByEmail   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([monetizationType, status])
  @@index([projectProfile, updatedAt])
  @@index([sourcePublisher])
  @@index([status, updatedAt])
}

model StoryDraft {
  id                  String           @id @default(cuid())
  storyCandidateId    String
  storyCandidateTitle String?
  sourceBlockId       String
  episodeKey          String?
  episodeNumber       Int?
  arrangementKey      String?
  title               String
  body                String
  notes               String?
  supportNotes        String?
  status              StoryDraftStatus @default(ROUGH)
  createdByUserId     String
  updatedByUserId     String?
  reviewedByUserId    String?
  approvedAt          DateTime?
  promotedAt          DateTime?
  promotedBlockId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  createdBy           User             @relation("StoryDraftCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy           User?            @relation("StoryDraftUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  reviewedBy          User?            @relation("StoryDraftReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([storyCandidateId, status])
  @@index([sourceBlockId, status])
  @@index([episodeKey, status])
  @@index([createdByUserId, createdAt])
}

model StudioWorkspace {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  ownerLabel  String?
  isPrivate   Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  projects    StudioProject[]
}

model StudioProject {
  id          String                @id @default(cuid())
  workspaceId String
  slug        String
  name        String
  description String?
  sourceLabel String?
  isPrivate   Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  workspace   StudioWorkspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   StudioDocument[]
  tags        StudioTag[]
  knowledgeNodes StudioKnowledgeNode[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model StudioDocument {
  id               String                 @id @default(cuid())
  projectId        String
  stableId         String                 @unique
  title            String
  sourceLabel      String?
  sourcePath       String?
  projectionStatus StudioProjectionStatus @default(private)
  isPrivate        Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  project          StudioProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks           StudioDocumentBlock[]
  taggedSpans      StudioTaggedSpan[]
  knowledgeNodes   StudioKnowledgeNode[]

  @@index([projectId, stableId])
  @@index([projectId, projectionStatus])
}

model StudioManuscript {
  id             String                 @id @default(cuid())
  ownerEmail     String
  title          String
  description    String?
  sourceFileName String?
  kind           StudioManuscriptKind   @default(WORKING)
  lastSnapshotAt DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  archivedAt     DateTime?

  snapshots      StudioManuscriptSnapshot[]

  @@index([ownerEmail, updatedAt])
  @@index([ownerEmail, kind, updatedAt])
  @@index([ownerEmail, lastSnapshotAt])
}

model StudioManuscriptSnapshot {
  id              String   @id @default(cuid())
  manuscriptId    String?
  ownerEmail      String
  title           String
  description     String?
  schemaVersion   Int
  sourceFileName  String?
  draftJson       Json
  contentHash     String?
  clientUpdatedAt DateTime?
  wordCount       Int      @default(0)
  characterCount  Int      @default(0)
  blockCount      Int      @default(0)
  structureCount  Int      @default(0)
  citedQuoteCount Int      @default(0)
  quoteReviewCount Int       @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  manuscript        StudioManuscript? @relation(fields: [manuscriptId], references: [id], onDelete: SetNull)

  @@index([ownerEmail, updatedAt])
  @@index([ownerEmail, createdAt])
  @@index([ownerEmail, manuscriptId, updatedAt])
  @@index([manuscriptId, updatedAt])
}

model StudioManuscriptCollaborationRoom {
  id                       String   @id @default(cuid())
  roomName                 String   @unique
  title                    String
  seedSnapshotId           String?
  seededAt                 DateTime?
  seededByEmail            String?
  lastCheckpointSnapshotId String?
  ydocState                Bytes?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([updatedAt])
  @@index([seedSnapshotId])
  @@index([lastCheckpointSnapshotId])
}

model StudioContentWorkspaceSnapshot {
  id              String   @id @default(cuid())
  ownerEmail      String
  title           String
  description     String?
  schemaVersion   Int
  workspaceJson   Json
  contentHash     String?
  projectCount    Int      @default(0)
  activeCount     Int      @default(0)
  readyCount      Int      @default(0)
  blockedCount    Int      @default(0)
  clientUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerEmail, updatedAt])
  @@index([ownerEmail, createdAt])
}

model StudioContentProject {
  id                   String   @id @default(cuid())
  ownerEmail           String
  localProjectId       String
  title                String
  kind                 String
  status               String
  stage                String
  description          String?
  notes                String?
  schemaVersion        Int
  projectJson          Json
  handoffJson          Json
  productionPacketJson Json?
  clientUpdatedAt      DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([ownerEmail, localProjectId])
  @@index([ownerEmail, updatedAt])
  @@index([ownerEmail, kind, updatedAt])
  @@index([ownerEmail, status, updatedAt])
}

model HgoStagedProjectionArtifact {
  id                    String   @id @default(cuid())
  ownerUserId           String?
  ownerEmail            String
  recordId              String
  artifactVersion       String
  artifactId            String
  projectionId          String
  projectionSlug        String
  projectionTitle       String
  projectionStatus      String
  projectionVisibility  String
  sourceBridgeVersion   String?
  artifactStatus        String
  recommendedNextAction String
  reviewStatus          String
  promotionReadiness    String
  artifactHash          String
  artifactJson          Json
  artifactSummaryJson   Json
  eventLogJson          Json
  blockerCount          Int      @default(0)
  warningCount          Int      @default(0)
  containsRealContent   String   @default("unknown")
  note                  String?
  reviewedAt            DateTime?
  reviewedByEmail       String?
  archivedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  publishCandidates     HgoEpisodePublishCandidate[]

  @@unique([ownerEmail, artifactHash])
  @@unique([ownerEmail, recordId])
  @@index([ownerEmail, updatedAt])
  @@index([ownerEmail, archivedAt, updatedAt])
  @@index([ownerEmail, projectionSlug, updatedAt])
  @@index([ownerEmail, reviewStatus, updatedAt])
  @@index([artifactId])
}

model HgoEpisodePublishCandidate {
  id                       String   @id @default(cuid())
  ownerUserId              String?
  ownerEmail               String
  candidateId              String
  sourceStagedArtifactId   String
  sourceRecordId           String
  sourceArtifactId         String
  sourceArtifactHash       String
  projectionId             String
  projectionSlug           String
  projectionTitle          String
  proposedRoute            String
  readinessState           String
  candidateStatus          String   @default("private-review")
  packetJson               Json
  reviewBriefJson          Json
  draftPacketJson          Json
  frontmatterJson          Json
  mdxDraft                 String
  blockerCount             Int      @default(0)
  warningCount             Int      @default(0)
  containsRealContent      String   @default("unknown")
  note                     String?
  createdByEmail           String?
  approvedAt               DateTime?
  approvedByEmail          String?
  archivedAt               DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  sourceStagedArtifact HgoStagedProjectionArtifact @relation(fields: [sourceStagedArtifactId], references: [id], onDelete: Restrict)

  @@unique([ownerEmail, candidateId])
  @@unique([ownerEmail, sourceRecordId])
  @@index([ownerEmail, updatedAt])
  @@index([ownerEmail, candidateStatus, updatedAt])
  @@index([ownerEmail, proposedRoute])
  @@index([sourceStagedArtifactId])
  @@index([projectionSlug])
}

model StudioDocumentBlock {
  id               String                 @id @default(cuid())
  documentId       String
  stableId         String
  order            Int
  title            String?
  body             String
  sourceLabel      String?
  sourcePath       String?
  externalId       String?
  projectionStatus StudioProjectionStatus @default(private)
  isPrivate        Boolean                @default(true)
  archivedAt       DateTime?
  archivedByLabel  String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  document         StudioDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  taggedSpans      StudioTaggedSpan[]
  knowledgeNodes   StudioKnowledgeNode[]

  @@unique([documentId, stableId])
  @@unique([documentId, order])
  @@index([documentId, order])
  @@index([documentId, archivedAt, order])
  @@index([externalId])
}

model StudioTag {
  id           String                  @id @default(cuid())
  projectId    String
  slug         String
  label        String
  description  String?
  category     StudioTagCategory       @default(meaning)
  nodeType     StudioKnowledgeNodeType @default(source_note)
  isPrivate    Boolean                 @default(true)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  project      StudioProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taggedSpans  StudioTaggedSpan[]
  knowledgeNodes StudioKnowledgeNode[]

  @@unique([projectId, slug])
  @@index([projectId, category])
  @@index([projectId, isActive])
}

model StudioTaggedSpan {
  id                    String                 @id @default(cuid())
  documentId            String
  blockId               String
  tagId                 String
  startOffset           Int
  endOffset             Int
  selectedText          String
  documentStableId      String
  documentTitleSnapshot String
  blockStableId         String
  blockTitleSnapshot    String?
  sourceLabel           String?
  sourcePath            String?
  sourceExternalId      String?
  projectionStatus      StudioProjectionStatus @default(private)
  isPrivate             Boolean                @default(true)
  createdByLabel        String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  document              StudioDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  block                 StudioDocumentBlock    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  tag                   StudioTag              @relation(fields: [tagId], references: [id], onDelete: Restrict)
  knowledgeNode         StudioKnowledgeNode?

  @@unique([blockId, tagId, startOffset, endOffset])
  @@index([documentId, blockId])
  @@index([tagId])
  @@index([projectionStatus, createdAt])
  @@index([documentStableId, blockStableId])
}

model StudioKnowledgeNode {
  id                    String                  @id @default(cuid())
  projectId             String
  documentId            String
  blockId               String
  taggedSpanId          String                  @unique
  tagId                 String
  tagLabel              String
  tagCategory           StudioTagCategory
  nodeType              StudioKnowledgeNodeType @default(source_note)
  sourceText            String
  title                 String
  body                  String
  projectionStatus      StudioProjectionStatus  @default(projection_not_approved)
  reviewStatus          String                  @default("draft")
  isPrivate             Boolean                 @default(true)
  documentStableId      String
  documentTitleSnapshot String
  blockStableId         String
  blockTitleSnapshot    String?
  spanStartOffset       Int
  spanEndOffset         Int
  sourceLabel           String?
  sourcePath            String?
  createdByLabel        String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  project               StudioProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document              StudioDocument          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  block                 StudioDocumentBlock     @relation(fields: [blockId], references: [id], onDelete: Cascade)
  taggedSpan            StudioTaggedSpan        @relation(fields: [taggedSpanId], references: [id], onDelete: Cascade)
  tag                   StudioTag               @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@index([projectId, projectionStatus])
  @@index([tagId])
  @@index([documentId, blockId])
  @@index([reviewStatus, createdAt])
}

// -----------------------------------------------------------------------------
// USER ENGAGEMENT MODELS (Massive Swings Pipeline)
// -----------------------------------------------------------------------------

model Collection {
  id          String    @id @default(cuid())
  userId      String
  slug        String    @unique
  name        String
  description String?
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippets    Snippet[]
  bookmarks   Bookmark[]

  @@unique([userId, slug])
  @@index([userId, isPublic])
}

model Snippet {
  id              String      @id @default(cuid())
  userId          String
  collectionId    String?
  sourceUrl       String?
  sourceTitle     String?
  highlightedText String
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection      Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([collectionId])
}

model Bookmark {
  id           String      @id @default(cuid())
  userId       String
  collectionId String?
  url          String
  title        String
  metadataJson Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@unique([userId, url])
  @@index([userId, createdAt])
  @@index([collectionId])
}
