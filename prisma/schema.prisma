  id              String   @id @default(cuid())
  userId          String
  personaId       String?  // The target avatar for this page
  name            String
  headline        String?
  subheadline     String?
  ctaText         String?
  status          String   @default("draft") // draft, published
  slug            String?  @unique
  views           Int      @default(0)
  conversions     Int      @default(0)
  campaignId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  leads           MarketingLead[]
  
  @@index([userId, status])
  @@index([organizationId])
}

model MarketingLead {
  id              String   @id @default(cuid())
  userId          String
  landingPageId   String?
  email           String
  name            String?
  status          String   @default("subscribed") // subscribed, unsubscribed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String?

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  landingPage     LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)

  @@index([userId, email])
  @@index([landingPageId])
  @@index([organizationId])
}

// -----------------------------------------------------------------------------
// EMAIL SEQUENCE AUTOMATOR (MARKETING)
// -----------------------------------------------------------------------------

model EmailSequence {
  id              String   @id @default(cuid())
  userId          String
  personaId       String?
  name            String
  status          String   @default("draft") // draft, active
  emailsJson      Json     // Array of email objects (subject, body, dayOffset)
  campaignId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([organizationId])
}

// -----------------------------------------------------------------------------
// CAMPAIGN SANDBOX (MARKETING)
// -----------------------------------------------------------------------------

model MarketingCampaign {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  status          String   @default("draft") // draft, active, completed
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId  String?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  landingPages    LandingPage[]
  emailSequences  EmailSequence[]

  @@index([userId, status])
  @@index([organizationId])
}

// -----------------------------------------------------------------------------
// ORGANIZATION & IDENTITY (QUIPSLY SAAS)
// -----------------------------------------------------------------------------

enum OrganizationRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            OrganizationMember[]
  feedbackTickets    FeedbackTicket[]
  userEvents         UserEvent[]
  subscription       Subscription?
  landingPages       LandingPage[]
  marketingLeads     MarketingLead[]
  emailSequences     EmailSequence[]
  marketingCampaigns MarketingCampaign[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(VIEWER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

enum FeedbackTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum FeedbackTicketType {
  BUG
  FEATURE_REQUEST
  GENERAL
}

model FeedbackTicket {
  id             String               @id @default(cuid())
  userId         String
  organizationId String?
  type           FeedbackTicketType
  status         FeedbackTicketStatus @default(OPEN)
  title          String
  description    String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model UserEvent {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  eventName      String
  payloadJson    Json
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([eventName])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// SUBSCRIPTION ENGINE (QUIPSLY SAAS)
// -----------------------------------------------------------------------------

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  stripeProductId String?  @unique
  price           Int      
  currency        String   @default("usd")
  interval        String   @default("month") 
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  planId               String
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([planId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// -----------------------------------------------------------------------------
// PUBLIC MARKETING (QUIPSLY.COM)
// -----------------------------------------------------------------------------

model WaitlistSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("pending") // pending, invited, active
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
