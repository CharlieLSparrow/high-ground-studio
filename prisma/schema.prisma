generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// First, ensure we have a basic User model (if not already present)
model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String?
  image    String?
  created  DateTime @default(now())
  updated  DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(uuid())
  userId          String    @ref("User.id")
  clientName      String
  appointmentDate DateTime
  status          String   @default("PENDING") @enum(["PENDING", "COMPLETED", "CANCELLED"])
  googleEventId   String?   @unique

  @@index([userId])
}
