enum QuipslyNodeType {
  PERSON
  QUOTE
  THEME
  SOURCE_WORK
  EVIDENCE
  LORELIST
}

enum QuipslyEdgeType {
  QUOTED_BY
  APPEARS_IN
  SUPPORTED_BY
  HAS_THEME
  CONTAINS
  RELATED_TO
  VARIANT_OF
}

model QuipslyNode {
  id          String          @id @default(cuid())
