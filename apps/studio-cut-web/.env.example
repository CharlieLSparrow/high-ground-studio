# Studio Cut local context. These values are safe placeholders for local dev.
VITE_STUDIO_CUT_PROJECT_ID="studio-cut-local-project"
VITE_STUDIO_CUT_BRANCH_ID="local-main"
VITE_STUDIO_CUT_CREATED_BY="local-web-editor"
# Optional media-vault migration status endpoint. Defaults to the local Vite
# migration-health API endpoint and falls back to the static
# /media-vault/migration-health.json file for smoke/local-only runs.
VITE_STUDIO_CUT_MEDIA_VAULT_STATUS_ENDPOINT=""
# Example only. Use the real internal allowlist in untracked local/hosting env.
VITE_STUDIO_CUT_ALLOWED_EMAILS="charlie@highgroundodyssey.com"
# Example domain allowlist. Values may include or omit the leading @.
VITE_STUDIO_CUT_ALLOWED_EMAIL_DOMAINS="highgroundodyssey.com"

# Firebase web config. Leave blank for Vite local dev mode only.
# Production builds should provide Firebase config and allowed email/domain rules.
# Do not commit real credential files, service accounts, media, or proxy packages.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
