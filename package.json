{
  "name": "high-ground-studio",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "motion": "pnpm --filter @high-ground/motion-engine build && pnpm --filter motion-lab dev",
    "studio": "pnpm --filter studio dev",
    "studio:build": "pnpm --filter studio build",
    "studio:db:up": "docker compose -f compose.studio.yml up -d --wait studio-postgres",
    "studio:db:down": "docker compose -f compose.studio.yml down",
    "studio:db:reset": "docker compose -f compose.studio.yml down -v && docker compose -f compose.studio.yml up -d --wait studio-postgres",
    "studio:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm studio",
    "studio:local:bootstrap": "pnpm studio:db:up && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm db:generate && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm db:push && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm studio:smoke:persistence",
    "studio:cloudbuild:image": "gcloud builds submit --config cloudbuild.studio.yaml .",
    "studio:cloudbuild:image:sha": "gcloud builds submit --config cloudbuild.studio.yaml --substitutions=_IMAGE_TAG=$(git rev-parse --short HEAD) .",
    "studio:cloudrun:preflight": "node scripts/studio-cloud-run-preflight.mjs",
    "studio:cloudrun:deploy": "node scripts/studio-cloud-run-deploy.mjs",
    "studio:cloudrun:test": "node --test scripts/studio-cloud-run-readiness.test.mjs",
    "web:cloudbuild:image": "gcloud builds submit --config cloudbuild.web.yaml .",
    "web:cloudbuild:image:sha": "gcloud builds submit --config cloudbuild.web.yaml --substitutions=_IMAGE_TAG=$(git rev-parse --short HEAD) .",
    "web:cloudrun:preflight": "node scripts/web-cloud-run-preflight.mjs",
    "web:cloudrun:seed-secrets": "node scripts/web-cloud-run-seed-secrets-from-env.mjs",
    "web:cloudrun:deploy": "node scripts/web-cloud-run-deploy.mjs",
    "web:cloudsql:prepare": "node scripts/web-cloudsql-target-prepare.mjs",
    "web:db:target:report": "node scripts/web-database-target-report.mjs",
    "web:domain:check": "node scripts/web-domain-readiness.mjs",
    "web:cloudrun:test": "node --test scripts/web-cloud-run-readiness.test.mjs",
    "progress:story:add": "node scripts/progress-story-add-entry.mjs",
    "progress:story:test": "node --test scripts/progress-story-add-entry.test.mjs",
    "studio:manuscript:test": "node --experimental-strip-types --test scripts/studio-manuscript-editor.test.mjs",
    "studio:manuscript:live-room:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-manuscript-live-room.test.mjs",
    "studio:hgo:agentic-smoke": "node --experimental-strip-types scripts/agentic-studio-hgo-smoke.test.mjs",
    "studio:hgo:browser-smoke": "node scripts/agentic-studio-hgo-browser-smoke.mjs",
    "studio:hgo:capture-auth-state": "node scripts/capture-studio-auth-state.mjs",
    "studio:collab:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-lab.test.mjs",
    "studio:collab:checkpoint:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-checkpoint-bridge.test.mjs",
    "studio:collab:adapter:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-manuscript-adapter.test.mjs",
    "studio:collab:span:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-span-semantics.test.mjs",
    "studio:collab:presence:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-presence.test.mjs",
    "studio:collab:review:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-review-notes.test.mjs",
    "studio:collab:annotation:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-annotation-durability.test.mjs",
    "studio:collab:annotation-log:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-annotation-event-log.test.mjs",
    "studio:collab:annotation-state:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-annotation-state.test.mjs",
    "studio:collab:room:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-room-identity.test.mjs",
    "studio:collab:agentic-smoke": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/agentic-studio-collab-lab-smoke.mjs",
    "hgo:projection:browser-smoke": "node --experimental-strip-types scripts/agentic-hgo-projection-browser-smoke.mjs",
    "hgo:projection:visual-smoke": "node scripts/agentic-hgo-projection-visual-smoke.mjs",
    "hgo:artifact:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/hgo-staged-artifact.test.mjs",
    "hgo:store-lab:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/hgo-staged-artifact-store-lab.test.mjs",
    "hgo:publish-candidate:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/hgo-publish-candidate-packet.test.mjs",
    "worldhub:domain:build": "pnpm --filter @high-ground/worldhub-domain build",
    "worldhub:domain:typecheck": "pnpm --filter @high-ground/worldhub-domain typecheck",
    "worldhub:integrations:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/worldhub-provider-definitions.test.mjs scripts/worldhub-webhook-signatures.test.mjs scripts/worldhub-calendar-events.test.mjs scripts/worldhub-growth-tools.test.mjs",
    "coaching:features:test": "node --experimental-strip-types --test scripts/coaching-features.test.mjs",
    "coaching:weekly-commitments:test": "node --experimental-strip-types --test scripts/coaching-weekly-commitments.test.mjs",
    "content-studio:domain:build": "pnpm --filter @high-ground/content-studio-domain build",
    "content-studio:domain:typecheck": "pnpm --filter @high-ground/content-studio-domain typecheck",
    "content-studio:packet:test": "node --experimental-strip-types --test scripts/content-studio-packet.test.mjs",
    "studio:structure:test": "node --experimental-strip-types --test scripts/studio-structure-mode.test.mjs",
    "studio:smoke:persistence": "node scripts/smoke-studio-persistence.mjs",
    "web": "pnpm --filter web dev",
    "engine:build": "pnpm --filter @high-ground/motion-engine build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed:membership-plans": "node --env-file=apps/web/.env.local scripts/seed-membership-plans.mjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "react-datepicker": "^9.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prisma": "^7.7.0"
  }
}
