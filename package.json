{
  "name": "high-ground-studio",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "motion": "pnpm --filter @high-ground/motion-engine build && pnpm --filter motion-lab dev",
    "studio": "pnpm --filter studio dev",
    "studio:build": "pnpm --filter studio build",
    "studio-cut": "pnpm --filter studio-cut-web dev",
    "studio-cut:agent-smoke": "python tools/studio-cut-local/studio_cut_local.py agent-smoke-test",
    "studio-cut:build": "pnpm --filter @high-ground/studio-cut-schema build && pnpm --filter studio-cut-web build",
    "studio-cut:local:doctor": "python tools/studio-cut-local/studio_cut_local.py doctor",
    "studio-cut:local:verify-episode": "python tools/studio-cut-local/studio_cut_local.py validate-episode-files",
    "studio-cut:local:validate-package": "python tools/studio-cut-local/studio_cut_local.py validate-generated-package",
    "studio-cut:local:rescue-sync-session": "python tools/studio-cut-local/studio_cut_local.py rescue-sync-session",
    "studio-cut:local:rescue-sync-status": "python tools/studio-cut-local/studio_cut_local.py rescue-sync-status",
    "studio-cut:local:render-rescue-sync-session": "python tools/studio-cut-local/studio_cut_local.py render-rescue-sync-session",
    "studio-cut:cloud-sync-smoke": "node scripts/studio-cut-cloud-sync-worker-smoke.mjs",
    "studio-cut:rescue-sync-package": "node scripts/studio-cut-cloud-sync-worker-smoke.mjs --only-scenario short --publish-package-scenario short --publish-package-dir tools/studio-cut-local/output/rescue-sync-publish-package",
    "studio-cut:rules-config-test": "node --test scripts/studio-cut-rules-config.test.mjs",
    "studio-cut:rules-test": "firebase emulators:exec --project demo-studio-cut-rules --only firestore,storage \"node --test scripts/studio-cut-rules.test.mjs\"",
    "studio-cut:typecheck": "pnpm --filter @high-ground/studio-cut-schema typecheck && pnpm --filter studio-cut-web typecheck",
    "studio-cut:verify": "node scripts/verify-studio-cut.mjs",
    "studio-cut:web-smoke": "node scripts/studio-cut-web-smoke.mjs",
    "studio:db:up": "docker compose -f compose.studio.yml up -d --wait studio-postgres",
    "studio:db:down": "docker compose -f compose.studio.yml down",
    "studio:db:reset": "docker compose -f compose.studio.yml down -v && docker compose -f compose.studio.yml up -d --wait studio-postgres",
    "studio:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm studio",
    "studio:local:bootstrap": "pnpm studio:db:up && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm db:generate && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm db:push && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm studio:smoke:persistence",
    "studio:cloudbuild:image": "gcloud builds submit --config cloudbuild.studio.yaml .",
    "studio:cloudbuild:image:sha": "gcloud builds submit --config cloudbuild.studio.yaml --substitutions=_IMAGE_TAG=$(git rev-parse --short HEAD) .",
    "studio:cloudrun:preflight": "node scripts/studio-cloud-run-preflight.mjs",
    "studio:cloudrun:test": "node --test scripts/studio-cloud-run-readiness.test.mjs",
    "studio:manuscript:test": "node --experimental-strip-types --test scripts/studio-manuscript-editor.test.mjs",
    "studio:structure:test": "node --experimental-strip-types --test scripts/studio-structure-mode.test.mjs",
    "studio:smoke:persistence": "node scripts/smoke-studio-persistence.mjs",
    "web": "pnpm --filter web dev",
    "engine:build": "pnpm --filter @high-ground/motion-engine build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed:membership-plans": "node --env-file=apps/web/.env.local scripts/seed-membership-plans.mjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "react-datepicker": "^9.1.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "firebase-tools": "15.18.0",
    "prisma": "^7.7.0"
  }
}
