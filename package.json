{
  "name": "high-ground-studio",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "motion": "pnpm --filter @high-ground/motion-engine build && pnpm --filter motion-lab dev",
    "studio": "pnpm --filter studio dev",
    "studio:build": "pnpm --filter studio build",
    "studio:db:up": "docker compose -f compose.studio.yml up -d --wait studio-postgres",
    "studio:db:down": "docker compose -f compose.studio.yml down",
    "studio:db:reset": "docker compose -f compose.studio.yml down -v && docker compose -f compose.studio.yml up -d --wait studio-postgres",
    "studio:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm studio",
    "studio:local:bootstrap": "pnpm studio:db:up && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm db:generate && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm db:push && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/high_ground_studio pnpm studio:smoke:persistence",
    "studio:cloudbuild:image": "gcloud builds submit --config cloudbuild.studio.yaml .",
    "studio:cloudbuild:image:sha": "gcloud builds submit --config cloudbuild.studio.yaml --substitutions=_IMAGE_TAG=$(git rev-parse --short HEAD) .",
    "studio:cloudrun:preflight": "node scripts/studio-cloud-run-preflight.mjs",
    "studio:cloudrun:test": "node --test scripts/studio-cloud-run-readiness.test.mjs",
    "studio:manuscript:test": "node --experimental-strip-types --test scripts/studio-manuscript-editor.test.mjs",
    "studio:hgo:agentic-smoke": "node --experimental-strip-types scripts/agentic-studio-hgo-smoke.test.mjs",
    "studio:hgo:browser-smoke": "node scripts/agentic-studio-hgo-browser-smoke.mjs",
    "studio:hgo:capture-auth-state": "node scripts/capture-studio-auth-state.mjs",
    "studio:collab:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-lab.test.mjs",
    "studio:collab:checkpoint:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/studio-collaboration-checkpoint-bridge.test.mjs",
    "studio:collab:agentic-smoke": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/agentic-studio-collab-lab-smoke.mjs",
    "hgo:projection:browser-smoke": "node --experimental-strip-types scripts/agentic-hgo-projection-browser-smoke.mjs",
    "hgo:projection:visual-smoke": "node scripts/agentic-hgo-projection-visual-smoke.mjs",
    "hgo:artifact:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/hgo-staged-artifact.test.mjs",
    "hgo:store-lab:test": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs --test scripts/hgo-staged-artifact-store-lab.test.mjs",
    "studio:structure:test": "node --experimental-strip-types --test scripts/studio-structure-mode.test.mjs",
    "studio:smoke:persistence": "node scripts/smoke-studio-persistence.mjs",
    "web": "pnpm --filter web dev",
    "engine:build": "pnpm --filter @high-ground/motion-engine build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed:membership-plans": "node --env-file=apps/web/.env.local scripts/seed-membership-plans.mjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "react-datepicker": "^9.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prisma": "^7.7.0"
  }
}
